generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Professores {
  id    Int    @id @default(autoincrement())
  nome  String
  email String
  senha String

  turmas Turmas[]
}

model Turmas {
  id   Int    @id @default(autoincrement())
  nome String

  professorId Int

  professor Professores @relation(fields: [professorId], references: [id])

  atividades Atividades[]
}

model Atividades {
  id        Int    @id @default(autoincrement())
  descricao String

  turmaId Int

  turma Turmas @relation(fields: [turmaId], references: [id])
}
